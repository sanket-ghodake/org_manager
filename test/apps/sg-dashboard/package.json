{
  "name": "sg-dashboard",
  "version": "1.0.0",
  "description": "SG_Dashboard with ultra-lean Fastify, Bun, and libSQL/SQLite.",
  "main": "backend/server.ts",
  "scripts": {
    "start": "bun run backend/server.ts",
    "test": "bun test",
    "lint": "bunx biome ci .",
    "format": "bunx biome format --write .",
    "postinstall": "bash scripts/setup-hooks.sh"
  },
  "dependencies": {
    "fastify": "^4.26.2",
    "@fastify/static": "^7.0.2",
    "@fastify/jwt": "^8.0.0",
    "@libsql/client": "^0.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^20.12.7"
  }
}
