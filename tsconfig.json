{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["src/backend/*"],
      "@database/*": ["src/database/*"],
      "@frontend/*": ["src/frontend/*"],
      "@apps/*": ["src/apps/*"],
      "@sdk/*": ["src/sdk/*"],
      "@test/*": ["test/*"]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx"
  ]
}
